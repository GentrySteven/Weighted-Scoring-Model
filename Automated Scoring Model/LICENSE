# Example configuration for a university archives
# Copy this file to config.yml in the project root and customize.

archivesspace:
  base_url: "https://archivesspace.university.edu/api"
  repository_id: 2

output:
  format: "google_sheets"
  spreadsheet_name: "Accession Data and Scores"

google_sheets:
  folder_id: "your_folder_id_here"
  spreadsheet_url: ""
  sharing:
    - email: "head.archivist@university.edu"
      role: "writer"
      notify: true
    - email: "processing.team@university.edu"
      role: "writer"
      notify: true

agents:
  donor_role: "source"

throttling:
  archivesspace: 0.5
  google_sheets: 1.0
  google_drive: 0.5
  batch_mode: true

retry:
  max_retries: 5

logging:
  level: "standard"
  directory: "/home/archivist/accession-sync/logs"
  consolidation_frequency: "weekly"

cache:
  directory: "/home/archivist/accession-sync/cache"

preview:
  directory: "/home/archivist/accession-sync/preview"

scheduling:
  frequency: "daily"
  time: "20:00"

notifications:
  recipient_email: "head.archivist@university.edu"
